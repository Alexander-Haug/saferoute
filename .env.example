# ── SafeRoute — variáveis de ambiente ──────────────────────────────
# Copie este arquivo para .env e preencha os valores antes de rodar.
# NUNCA commite o arquivo .env com valores reais.

# Chave secreta Flask — OBRIGATÓRIA em produção.
# Gere uma com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=coloque-aqui-sua-chave-gerada

# Token público Mapbox (começa com pk.) — exposto no HTML, isso é correto.
MAPBOX_TOKEN=pk.sua_chave_mapbox_aqui

# URL do banco de dados (SQLite local ou PostgreSQL no Render)
# Desenvolvimento: deixe em branco (usa saferoute.db automático)
# Produção: DATABASE_URL=postgresql://user:pass@host/dbname
DATABASE_URL=

# URL pública do app no Render (usado pelo healthcheck)
APP_URL=https://seu-app.onrender.com

# Ative o modo debug APENAS em desenvolvimento local
FLASK_DEBUG=1
